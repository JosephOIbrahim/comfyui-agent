# ══════════════════════════════════════════════════════════
# Video Recreation Agent — Bridge Configuration
# ══════════════════════════════════════════════════════════
# Copy this to .env and fill in YOUR paths.
# These connect your comfyui-agent repo to your ComfyUI install.

# ── Where is ComfyUI installed? ──────────────────────────
# This is the folder with main.py, models/, custom_nodes/, etc.
# Windows example: C:\Users\joe\ComfyUI
# Mac example:     /Applications/ComfyUI
COMFYUI_PATH=G:/COMFYUI_Database

# ── ComfyUI server address ───────────────────────────────
# Default is localhost. Change if running on another machine.
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# ── Where is THIS repo (comfyui-agent)? ─────────────────
AGENT_PATH=/path/to/comfyui-agent

# ── Working directory for outputs ────────────────────────
# All generated assets, storyboards, workflows go here.
# Recommend: inside the agent repo or a dedicated folder.
WORKSPACE=/path/to/comfyui-agent/workspace

# ── API Keys (for cloud-based generation models) ────────
# Kling 3.0, LTX, etc. run as API nodes = cloud generation
# Leave blank if only using local models (FLUX, Wan, etc.)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CIVITAI_API_TOKEN=

# ── Claude Code model ───────────────────────────────────
AGENT_MODEL=claude-opus-4-6-20250929
